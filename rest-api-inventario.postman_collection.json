                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/registro",
              "host": ["{{base_url}}"],
              "path": ["api", "registro"]
            },
            "description": "## Registrar un nuevo usuario\n\nCrea un nuevo usuario en el sistema. La contraseña se encripta automáticamente con **bcrypt** antes de almacenarse.\n\n### Body (JSON)\n| Campo | Tipo | Requerido | Descripción |\n|-------|------|-----------|-------------|\n| username | string | Sí | Nombre de usuario único |\n| password | string | Sí | Contraseña del usuario |\n\n### Respuestas\n\n**201 - Registro exitoso:**\n```json\n{\n  \"exito\": true,\n  \"mensaje\": \"Registro exitoso\"\n}\n```\n\n**400 - Campos faltantes:**\n```json\n{\n  \"exito\": false,\n  \"mensaje\": \"El usuario y la contraseña son obligatorios\"\n}\n```\n\n**409 - Usuario ya existe:**\n```json\n{\n  \"exito\": false,\n  \"mensaje\": \"El usuario ya se encuentra registrado\"\n}\n```\n\n**500 - Error del servidor:**\n```json\n{\n  \"exito\": false,\n  \"mensaje\": \"Error interno del servidor\"\n}\n```"
          },
          "response": [
            {
              "name": "201 - Registro exitoso",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
